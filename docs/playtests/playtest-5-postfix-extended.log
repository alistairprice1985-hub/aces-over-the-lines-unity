# CYCLE 2 — Climb 39.37s — THE CRITICAL VALIDATION
# Entry: alt 533, vy -45.2, v 73.3 (low-altitude entry, high vy)
# Speed bleeds from 73 m/s during the climb to a minimum of 28.8 m/s
# WITHOUT Commit 7's airspeed-aware pitch scaling, this regime stalled the
# wings in baseline playtest 2 cycle 6, leading to eventual crash.
# WITH Commit 7, vy stays positive throughout and aircraft recovers to 700m.
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=-0.02 elv=0.02 thr=0.00)  alt=533  vy=-45.2  v=73.3
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=-0.29 elv=0.81 thr=0.00)  alt=511  vy=-40.4  v=74.4
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=-0.07 elv=0.43 thr=0.00)  alt=496  vy=-16.9  v=72.8
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=-0.02 elv=0.23 thr=0.00)  alt=492  vy=-0.3  v=70.8
# vy now positive (recovered from the dive), speed bleeding
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=-0.01 elv=0.13 thr=0.00)  alt=494  vy=8.2  v=68.8
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=0.00 elv=0.08 thr=0.00)  alt=500  vy=12.2  v=66.6
# [...long climb continues, vy oscillates 4-15 m/s positive throughout, speed drops 66 → 28.8 m/s minimum]
# Speed nadir at v=28.8: airspeedRatio = 28.8/45 = 0.64, effective pitch setpoint = 0.3 × 0.64 = 0.192
# Without Commit 7 this would have been a death spiral; with it the wings produce
# manageable lift and vy stays positive.
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=0.00 elv=0.02 thr=0.50)  alt=601  vy=0.3  v=28.8
# [throttle ramps from 0 to 1.00 as speed recovers, vy slowly increases back]
[AI-CMD] state=Climb  set(bnk=0.00 ptc=0.30 spd=45 fire=0)  out(ail=0.00 elv=0.02 thr=1.00)  alt=699  vy=6.5  v=39.8
[AI] Climb → Patrol  range=434m  alt=700m  vy=6.6m/s  dwelled=39.37s
[AI] Patrol → Engage  range=433m  alt=702m  vy=6.3m/s  dwelled=0.21s

# CYCLE 3 — Engage 52.28s — the new dominant inefficiency
# Entry at speed 39.3 (low), starts climbing engagement
# Long sequence of bank/pitch reversals as player manoeuvres
# Speed never recovers above 53 m/s during this entire engagement
[AI-CMD] state=Engage  set(bnk=-0.70 ptc=0.50 spd=55 fire=0)  out(ail=-0.30 elv=0.20 thr=0.30)  alt=702  vy=6.1  v=39.3
# [climbing engagement: alt 702 → 776, vy oscillates 0-23 m/s, multiple bank reversals as ail saturates ±1.00]
# [player evidently manoeuvres aggressively — bank flips from +0.70 to -0.70 several times]
# [eventually ptc flips to -0.50 (player went below), AI enters steep dive]
# [alt drops 776 → 668, vy -45.5]
[AI] Engage → Climb  range=214m  alt=668m  vy=-45.5m/s  dwelled=52.28s

