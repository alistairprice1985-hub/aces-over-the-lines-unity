# CYCLE 2 — Engage 6.17s starts climbing (player above), ends in dive
[AI-CMD] state=Engage  set(bnk=0.70 ptc=-0.50 spd=55 fire=0)  out(ail=0.45 elv=-0.30 thr=0.00)  alt=706  vy=13.8  v=61.6
